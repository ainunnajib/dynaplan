DYNAPLAN_DATABASE_URL=postgresql+asyncpg://localhost:5432/dynaplan
DYNAPLAN_DATABASE_READ_REPLICA_URLS=
DYNAPLAN_DATABASE_POOL_SIZE=20
DYNAPLAN_DATABASE_MAX_OVERFLOW=10
DYNAPLAN_DATABASE_POOL_TIMEOUT=30
DYNAPLAN_DATABASE_POOL_RECYCLE=1800
DYNAPLAN_REDIS_URL=redis://localhost:6379/0
DYNAPLAN_SECRET_KEY=change-me-in-production
DYNAPLAN_DEBUG=true
DYNAPLAN_FRONTEND_URL=http://localhost:3000
DYNAPLAN_AUTO_CREATE_SCHEMA=false
