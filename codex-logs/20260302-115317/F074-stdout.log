+    module = await create_module(client, token, model_id)
+    module_id = module["id"]
+
+    resp = await client.post(
+        f"/modules/{module_id}/line-items",
+        json={
+            "name": "Invalid Rule",
+            "conditional_format_rules": [
+                {
+                    "id": str(uuid.uuid4()),
+                    "operator": "gt",
+                    "value": 10,
+                    "style": {},
+                }
+            ],
+        },
+        headers=auth_headers(token),
+    )
+    assert resp.status_code == 422
+
+
