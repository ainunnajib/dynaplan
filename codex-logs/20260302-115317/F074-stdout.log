+    rule_payload = [
+        {
+            "id": rule_id,
+            "name": "High value",
+            "enabled": True,
+            "operator": "gt",
+            "value": 100,
+            "style": {
+                "background_color": "#ffedd5",
+                "text_color": "#9a3412",
+                "bold": True,
+                "icon": "warning",
+                "number_format": "currency",
+            },
+        }
+    ]
+
+    resp = await client.post(
+        f"/modules/{module_id}/line-items",
+        json={
+            "name": "Revenue",
+            "conditional_format_rules": rule_payload,
