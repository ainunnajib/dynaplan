+        color = value.strip()
+        if color == "":
+            return None
+        if re.fullmatch(r"^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6})$", color) is None:
+            raise ValueError("must be a hex color like #RRGGBB")
