+                Text
+                <input
+                  type="color"
+                  value={rule.style.text_color ?? "#111827"}
+                  onChange={(event) =>
+                    setDraftRules((prev) =>
+                      prev.map((candidate) =>
+                        candidate.id === rule.id
+                          ? {
+                              ...candidate,
+                              style: {
+                                ...candidate.style,
