 from app.models.module import LineItemFormat, SummaryMethod
 
 
 # ── Module schemas ─────────────────────────────────────────────────────────────
 
+
+class ConditionalFormatOperator(str, enum.Enum):
+    gt = "gt"
+    gte = "gte"
+    lt = "lt"
+    lte = "lte"
+    eq = "eq"
+    neq = "neq"
