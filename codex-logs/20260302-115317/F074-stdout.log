 }
@@ -174,6 +175,7 @@
     | "closing_balance"
     | "weighted_average"
     | null;
+  conditional_format_rules: ConditionalFormatRule[];
   created_at: string;
   updated_at: string;
 }
@@ -210,6 +212,34 @@
   value: number | string | boolean | null;
 }
 
+export type ConditionalFormatOperator =
+  | "gt"
+  | "gte"
+  | "lt"
+  | "lte"
+  | "eq"
+  | "neq";
+
+export type ConditionalNumberFormat = "number" | "currency" | "percentage";
+
