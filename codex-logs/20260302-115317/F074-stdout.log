+  text_color?: string | null;
+  bold?: boolean | null;
+  italic?: boolean | null;
+  number_format?: ConditionalNumberFormat | null;
+  icon?: string | null;
+}
+
+export interface ConditionalFormatRule {
+  id: string;
+  name?: string | null;
+  enabled: boolean;
+  operator: ConditionalFormatOperator;
+  value: number | string | boolean;
+  style: ConditionalFormatStyle;
+}
