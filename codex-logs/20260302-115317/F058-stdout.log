+}
+
+export interface SavedViewUpdateInput {
+  name?: string;
+  view_config?: SavedViewConfig;
+  is_default?: boolean;
+}
+
 // ── API helpers ───────────────────────────────────────────────────────────────
 
 export async function getWorkspaces(): Promise<Workspace[]> {
@@ -282,6 +327,42 @@
   });
 }
 
+export async function getSavedViews(moduleId: string): Promise<SavedView[]> {
