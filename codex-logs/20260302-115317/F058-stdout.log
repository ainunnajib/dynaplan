+        json={"name": "Hijacked"},
+        headers=auth_headers(token_b),
+    )
+    assert patch_b_resp.status_code == 404
+
+    delete_b_resp = await client.delete(
+        f"/saved-views/{saved_view_id}",
+        headers=auth_headers(token_b),
