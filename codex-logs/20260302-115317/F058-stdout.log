+      />
+      <DataGrid
+        moduleId={moduleId}
+        lineItems={lineItems}
+        dimensions={dimensions}
+        dimensionItems={dimensionItems}
+        initialCells={initialCells}
+        appliedViewConfig={currentViewConfig}
+        onViewConfigChange={handleViewConfigChange}
+      />
+    </div>
   );
 }
