  const [rawPath, rawQuery] = path.split("?");
  let normalized = rawPath;

  // Frontend still uses legacy "/api/*" paths in many places.
  if (normalized === "/api") {
    normalized = "/";
  } else if (normalized.startsWith("/api/")) {
    normalized = normalized.slice(4);
