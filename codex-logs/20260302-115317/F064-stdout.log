+                return
+            if not schedule.is_enabled:
+                return
+
+            run = await trigger_run(db, schedule_id=schedule_id)
+            await execute_run(db, run)
+    except Exception:  # noqa: BLE001
+        logger.exception(
+            "CloudWorks cron execution failed for schedule %s",
+            schedule_id,
+        )
