+            return
+
+        scheduler = self._scheduler
+        if scheduler is None:
+            return
+
+        try:
+            scheduler.remove_job(str(schedule_id))
+        except Exception:
+            logger.debug(
+                "CloudWorks schedule %s was not registered in runtime",
