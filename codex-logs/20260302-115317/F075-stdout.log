+      items: Array<DimensionItem & { sort_order?: number }>;
+    }
+  >(`/api/dimensions/${dimensionId}/items/page${query ? `?${query}` : ""}`);
+  return {
+    ...payload,
+    items: payload.items.map((row) => ({
+      ...row,
+      order: row.order ?? row.sort_order ?? 0,
+    })),
+  };
