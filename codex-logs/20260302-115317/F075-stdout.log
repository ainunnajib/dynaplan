+                dimension_member_ids=_dimension_member_ids(cell.dimension_key),
+                value=value,
+            )
+        )
+
+    return ModuleCellPageResponse(
+        cells=rows,
+        total_count=total_count,
+        offset=offset,
+        limit=limit,
+        has_more=(offset + limit) < total_count,
