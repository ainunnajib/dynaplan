+
+    items_result = await db.execute(
+        select(DimensionItem)
+        .where(*filters)
+        .order_by(DimensionItem.sort_order, DimensionItem.name)
+        .offset(offset)
+        .limit(limit)
+    )
+    return total_count, list(items_result.scalars().all())
+
+
