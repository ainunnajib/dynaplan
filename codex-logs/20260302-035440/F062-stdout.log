+
+        release.set()
+        await executor.wait_for_job(running_job.id, timeout_seconds=1.0)
+        finished = await executor.wait_for_job(queued_job.id, timeout_seconds=1.0)
+        assert finished is not None
+        assert finished.state == JobState.cancelled
+    finally:
+        await executor.stop()
+
+
