+    def _percentile(self, values: List[float], k: float, context_label: str) -> float:
+        if len(values) == 0:
+            raise FormulaError(f"{context_label} called with empty range")
+        if k > 1.0 and k <= 100.0:
+            k = k / 100.0
+        if k < 0.0 or k > 1.0:
