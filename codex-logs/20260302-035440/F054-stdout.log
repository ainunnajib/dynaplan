+            return ""
+
+        if (
+            len(text) >= 2
+            and (
+                (text.startswith('"') and text.endswith('"'))
+                or (text.startswith("'") and text.endswith("'"))
+            )
+        ):
+            return text[1:-1]
+
+        upper = text.upper()
+        if upper == "TRUE":
+            return True
+        if upper == "FALSE":
+            return False
+
+        try:
+            return float(text)
+        except ValueError:
+            return text
