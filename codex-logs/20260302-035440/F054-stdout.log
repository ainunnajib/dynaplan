+        result = evaluate_formula("PERCENTILE(Values, 0.25)", {"Values": [10, 20, 30, 40]})
+        assert result == 17.5
+
+    def test_percentile_accepts_percentage_k(self):
+        result = evaluate_formula("PERCENTILE(Values, 25)", {"Values": [10, 20, 30, 40]})
+        assert result == 17.5
