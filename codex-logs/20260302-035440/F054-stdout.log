+
+        rank = k * (len(ordered) - 1)
+        lower = int(math.floor(rank))
+        upper = int(math.ceil(rank))
+        if lower == upper:
+            return ordered[lower]
+        weight = rank - lower
+        return ordered[lower] + (ordered[upper] - ordered[lower]) * weight
+
+    def _growth_known_pairs(
