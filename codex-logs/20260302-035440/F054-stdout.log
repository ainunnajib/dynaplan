+    def _try_num(self, value: Any) -> Optional[float]:
+        if isinstance(value, bool):
+            return float(value)
+        if isinstance(value, (int, float)):
+            return float(value)
+        if isinstance(value, str):
+            text = value.strip()
+            if len(text) == 0:
+                return None
+            try:
+                return float(text)
+            except ValueError:
+                return None
+        return None
