+            if left_num is not None and right_num is not None:
+                return left_num == right_num
+            return self._coerce_text_value(value) == self._coerce_text_value(operand)
+
+        if operator == "<>":
+            if left_num is not None and right_num is not None:
+                return left_num != right_num
+            return self._coerce_text_value(value) != self._coerce_text_value(operand)
+
+        if left_num is not None and right_num is not None:
