+class TestAdvancedAggregationFunctions:
+    def test_sumif_numeric_criteria(self):
+        result = evaluate_formula(
+            'SUMIF(Sales, ">15")',
+            {"Sales": [10, 20, 30]},
+        )
+        assert result == 50.0
+
+    def test_countif_text_criteria(self):
+        result = evaluate_formula(
+            "COUNTIF(Statuses, StatusCriteria)",
+            {
+                "Statuses": ["Open", "Closed", "Open", "Hold"],
+                "StatusCriteria": "Open",
+            },
+        )
+        assert result == 2.0
+
