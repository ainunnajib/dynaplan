+        result = evaluate_formula("MEDIAN(Values)", {"Values": [7, 1, 3]})
+        assert result == 3.0
+
+    def test_median_even_range(self):
+        result = evaluate_formula("MEDIAN(Values)", {"Values": [1, 2, 3, 4]})
+        assert result == 2.5
+
