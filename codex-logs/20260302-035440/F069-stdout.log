+    assert second.status_code == 200
+    assert second.json()["value"] == 99.0
+
+
+@pytest.mark.asyncio
+async def test_enforce_storage_limit_mb_on_cell_write(client: AsyncClient):
+    token = await register_and_login(client, "quota_storage@example.com")
