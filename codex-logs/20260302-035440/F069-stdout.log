+    assert data["workspace_id"] == workspace_id
+    assert data["max_models"] == 100
+    assert data["max_cells_per_model"] == 1_000_000
+    assert data["max_dimensions_per_model"] == 200
+    assert data["storage_limit_mb"] == 1024
