+    )
+    dataset = connector.read()
+    assert dataset.to_dict(orient="records") == [
+        {"sku": "A1", "qty": 5},
+        {"sku": "B2", "qty": 9},
+    ]
+
+    connector.write(dataset)
+
+    assert len(captured_calls) == 2
+    assert captured_calls[1]["method"] == "POST"
+    assert captured_calls[1]["json"] == [
+        {"sku": "A1", "qty": 5},
+        {"sku": "B2", "qty": 9},
+    ]
+
