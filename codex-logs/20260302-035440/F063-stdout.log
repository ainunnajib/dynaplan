+
+    reader = DatabaseConnector(
+        config={
+            "connection_string": connection_string,
+            "query": "SELECT id, total FROM source_table ORDER BY id",
+        }
+    )
+    dataset = reader.read()
+    assert dataset.to_dict(orient="records") == [
+        {"id": 1, "total": 100.0},
+        {"id": 2, "total": 250.5},
+    ]
+
+    writer = DatabaseConnector(
+        config={
+            "connection_string": connection_string,
+            "table": "target_table",
+            "if_exists": "replace",
+        }
