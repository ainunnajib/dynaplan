+    target_path = tmp_path / "output.csv"
+
+    reader = LocalFileConnector(config={"path": str(source_path), "format": "csv"})
+    frame = reader.read()
+
+    assert list(frame.columns) == ["name", "amount"]
+    assert frame.to_dict(orient="records") == [
