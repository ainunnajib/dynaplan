+) -> None:
+    """Validate dimension_members against the line item's applies-to dimensions."""
+    line_item_result = await db.execute(
+        select(LineItem)
+        .where(LineItem.id == line_item_id)
+        .options(selectinload(LineItem.line_item_dimensions))
