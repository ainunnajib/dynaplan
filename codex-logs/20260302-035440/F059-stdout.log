+async def _validate_cell_dimensions(
+    db: AsyncSession,
+    line_item_id: uuid.UUID,
+    dimension_members: List[uuid.UUID],
+) -> None:
+    """Validate dimension_members against the line item's applies-to dimensions."""
+    line_item_result = await db.execute(
