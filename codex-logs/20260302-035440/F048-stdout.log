+}
+
+#[test]
+fn recalc_rejects_non_numeric_formula_results() {
+    let input = seeded_uuid(130);
+    let text_node = seeded_uuid(131);
+    let cell_key = key(556);
+
+    let mut graph = DependencyGraph::new();
