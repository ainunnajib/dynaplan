+#[test]
+fn aggregation_helpers_support_sum_average_and_count() {
+    let values = (1..=10).map(|v| v as f64).collect::<Vec<f64>>();
+
+    assert_eq!(sum_slice(&values), 55.0);
+    assert_eq!(average_slice(&values), Some(5.5));
