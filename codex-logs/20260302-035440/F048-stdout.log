+            right,
+            FormulaSpec::new("A * 3", HashMap::from([("A".to_string(), input)])),
+        ),
+    ]);
+
+    let mut model = ModelState::new();
+    model.write_numeric_cell(input, cell_key.clone(), 4.0);
+
+    let orchestrator = RecalcOrchestrator::new(formulas);
