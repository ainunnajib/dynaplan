+        assert_eq!(
+            model.read_numeric_cell(line_items.last().unwrap(), &dim_key),
+            Some(sample_index as f64 + 49.0)
+        );
+    }
+
+    assert_eq!(result.recalculated_line_items, 49);
+    assert_eq!(result.recalculated_cells, 4_900_000);
