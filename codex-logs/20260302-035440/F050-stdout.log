pub fn sum_slice(values: &[f64]) -> f64 {
    const CHUNK_SIZE: usize = 8;

    let mut total = 0.0;
    let mut idx = 0usize;

    while idx + CHUNK_SIZE <= values.len() {
        total += values[idx]
            + values[idx + 1]
            + values[idx + 2]
            + values[idx + 3]
