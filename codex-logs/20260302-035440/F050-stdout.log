+) -> PyResult<f64> {
+    let _ = handle;
+    let parsed_method = SummaryMethod::parse(method)
+        .map_err(|err| PyValueError::new_err(format!("Invalid summary method: {}", err)))?;
+    Ok(aggregate_values(&values, parsed_method))
+}
