+#[pyfunction]
+fn spread_top_down(
+    handle: &ModelHandle,
+    total: f64,
+    member_count: usize,
+    method: &str,
+    weights: Option<Vec<f64>>,
+    existing_values: Option<Vec<f64>>,
+) -> PyResult<Vec<f64>> {
