+}
+
+impl SummaryMethod {
+    pub fn parse(value: &str) -> Result<Self, SpreadError> {
+        match value.trim().to_ascii_lowercase().as_str() {
+            "sum" => Ok(Self::Sum),
+            "average" => Ok(Self::Average),
+            "min" => Ok(Self::Min),
+            "max" => Ok(Self::Max),
+            "count" => Ok(Self::Count),
+            "first" => Ok(Self::First),
+            "last" => Ok(Self::Last),
