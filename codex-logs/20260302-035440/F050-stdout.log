+#[pyfunction]
+fn spread_top_down(
+    handle: &ModelHandle,
+    total: f64,
+    member_count: usize,
+    method: &str,
+    weights: Option<Vec<f64>>,
+    existing_values: Option<Vec<f64>>,
+) -> PyResult<Vec<f64>> {
+    let _ = handle;
+    let parsed_method = SpreadMethod::parse(method)
+        .map_err(|err| PyValueError::new_err(format!("Invalid spread method: {}", err)))?;
+    spread_value(
+        total,
