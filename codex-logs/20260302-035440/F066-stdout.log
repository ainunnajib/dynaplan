+    client: AsyncClient,
+    token: str,
+    dimension_id: str,
+    name: str,
+    code: str,
+    parent_id: str = None,
+    sort_order: int = 0,
+) -> dict:
+    body = {
+        "name": name,
+        "code": code,
+        "sort_order": sort_order,
