+async def _get_model_ids_for_line_items(
+    db: AsyncSession,
+    line_item_ids: List[uuid.UUID],
+) -> Dict[uuid.UUID, uuid.UUID]:
+    """Map line_item_id -> model_id for a set of line items."""
+    if not line_item_ids:
