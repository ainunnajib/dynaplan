+#[test]
+fn three_node_cycle() {
+    let (graph, labels) = make_graph(&[("B", "A"), ("C", "B"), ("A", "C")]);
+    assert!(graph.has_cycle());
+    let cycles = graph.detect_cycles();
+    let involved = cycles
+        .into_iter()
