+
+    for (idx, rendered) in rendered_args.iter().enumerate() {
+        result = result.replace(&format!("{{{}}}", idx), rendered);
+    }
+    for rendered in &rendered_args {
+        if !result.contains("{}") {
+            break;
+        }
+        result = result.replacen("{}", rendered, 1);
+    }
+
+    Ok(FormulaValue::Text(result))
+}
