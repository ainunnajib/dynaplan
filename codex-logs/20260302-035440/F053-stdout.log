+    let text = evaluator.str_value(&args[0], name)?;
+    let old_text = evaluator.str_value(&args[1], name)?;
+    let new_text = evaluator.str_value(&args[2], name)?;
+    Ok(FormulaValue::Text(text.replace(&old_text, &new_text)))
