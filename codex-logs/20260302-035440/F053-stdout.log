+    let parsed = normalized.parse::<f64>().map_err(|_| {
+        FormulaError::new(format!("{} cannot parse numeric text: {:?}", name, text))
+    })?;
+    if is_percent {
+        Ok(FormulaValue::Number(parsed / 100.0))
+    } else {
