+        current
+    } else {
+        let today = current_system_date();
+        return Ok(FormulaValue::Text(format!(
+            "MTD {:04}-{:02}",
+            today.year(),
+            today.month()
+        )));
+    };
+
+    let (start, _) = period_bounds(period, name)?;
