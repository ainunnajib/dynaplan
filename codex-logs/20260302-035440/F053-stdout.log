+    let pattern = evaluator.str_value(&args[1], name)?.trim().to_string();
+    if pattern.is_empty() || pattern.eq_ignore_ascii_case("GENERAL") {
+        return Ok(FormulaValue::Text(compact_number_text(number)));
+    }
