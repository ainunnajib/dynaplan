+    let search = evaluator.str_value(&args[0], name)?;
+    let text = evaluator.str_value(&args[1], name)?;
+    if search.is_empty() {
+        return Ok(FormulaValue::Number(1.0));
+    }
+    if let Some(byte_idx) = text.find(&search) {
+        let position = text[0..byte_idx].chars().count() + 1;
