    pub(crate) fn flatten_numbers(
        &self,
        args: &[FormulaValue],
        context_label: &str,
    ) -> Result<Vec<f64>, FormulaError> {
        let mut result = Vec::new();
        for arg in args {
            match arg {
                FormulaValue::List(values) => {
                    for item in values {
                        result.push(self.num(item, context_label)?);
                    }
                }
                _ => result.push(self.num(arg, context_label)?),
            }
