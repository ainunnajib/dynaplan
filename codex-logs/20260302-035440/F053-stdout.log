+    let result = as_text(ev("MAKETEXT(\"{} {}\", \"Hello\", \"World\")", vec![]));
+    assert_eq!(result, "Hello World");
+}
+
+#[test]
+fn yeartodate_uses_current_period() {
+    let result = as_text(ev(
